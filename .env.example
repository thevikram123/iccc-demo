# VITE_WORKER_URL: URL of your deployed Cloudflare Worker (Gemini proxy).
# Set this in GitHub repository secrets as WORKER_URL, then the deploy workflow
# passes it as VITE_WORKER_URL at build time so Vite bakes it into the bundle.
VITE_WORKER_URL="https://iccc-gemini-proxy.YOUR-SUBDOMAIN.workers.dev"

# GEMINI_API_KEY: No longer needed here — store it as a secret directly in the
# Cloudflare Worker (Workers & Pages → your worker → Settings → Variables → Secrets).

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
