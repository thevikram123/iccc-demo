# VITE_API_PROXY_URL: The public URL of your deployed Cloudflare Worker proxy.
# The worker holds the Gemini API key securely — it never appears in the frontend bundle.
# Deploy the worker from the /worker directory using: wrangler deploy
# Then set the worker URL here and in GitHub Secrets as VITE_API_PROXY_URL.
VITE_API_PROXY_URL="https://iccc-copilot-proxy.<your-subdomain>.workers.dev"
